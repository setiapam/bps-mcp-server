# === Required ===
BPS_API_KEY=your_api_key_here          # Dari https://webapi.bps.go.id

# === Optional (with defaults) ===
# BPS_API_BASE_URL=https://webapi.bps.go.id/v1
# BPS_DEFAULT_LANG=ind                 # ind | eng
# BPS_DEFAULT_DOMAIN=0000              # 0000 = Nasional
# BPS_CACHE_ENABLED=true
# BPS_CACHE_MAX_ENTRIES=500
# BPS_LOG_LEVEL=info                   # debug | info | warn | error

