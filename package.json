{
  "name": "bps-mcp-server",
  "version": "0.2.0",
  "description": "MCP server for BPS (Badan Pusat Statistik) Indonesia statistics data",
  "author": "Murphi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/setiapam/bps-mcp-server.git"
  },
  "homepage": "https://github.com/setiapam/bps-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/setiapam/bps-mcp-server/issues"
  },
  "type": "module",
  "bin": {
    "bps-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc --noEmit --project tsconfig.worker.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cheerio": "^1.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250414.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.3",
    "eslint": "^10.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.1.2",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "bps",
    "statistics",
    "indonesia",
    "model-context-protocol",
    "ai",
    "claude",
    "data"
  ]
}
